---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import { normalizeBlogSlug } from "../../utils/getPath";
import { calculateReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: normalizeBlogSlug(post.id, post.filePath) },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = calculateReadingTime(post.body ?? "");
const slug = normalizeBlogSlug(post.id, post.filePath);
---

<BlogPostLayout {...post.data} slug={slug} readingTime={readingTime} editPath={post.filePath}>
  <Content />
</BlogPostLayout>
